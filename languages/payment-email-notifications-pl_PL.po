msgstr "Wolny"

#: admin-templates/settings.php:119
#: functions-private.php:94
msgid "Sat"
msgstr "Powiedział"

#: admin-templates/settings.php:120
#: functions-private.php:95
msgid "Sun"
msgstr "Oni"

#: admin-templates/settings.php:126
msgid "Send On"
msgstr "Prześlij dalej"

#: admin-templates/settings.php:142
msgid "Emails due on excluded days will be sent on the next allowed day."
msgstr "Wiadomości e-mail, których wysłanie przypada na dni wyłączone z harmonogramu, zostaną wysłane następnego dnia, w którym wysyłka jest dozwolona."

#: admin-templates/settings.php:150
msgid "Custom Meta Tokens"
msgstr "Niestandardowe tokeny meta"

#: admin-templates/settings.php:158
msgid "Order Meta Keys"
msgstr "Zamów klucze Meta"

#: admin-templates/settings.php:166
msgid "One meta key per line. These become available as {{order.meta.KEY}} tokens in email templates."
msgstr "W każdym wierszu jeden klucz meta. Klucze te są dostępne w szablonach wiadomości e-mail jako tokeny {{order.meta.KEY}}."

#: admin-templates/settings.php:174
msgid "Customer Meta Keys"
msgstr "Klucze meta klienta"

#: admin-templates/settings.php:182
msgid "One meta key per line. These become available as {{customer.meta.KEY}} tokens in email templates."
msgstr "Jeden klucz meta w każdym wierszu. Klucze te są dostępne w szablonach wiadomości e-mail jako tokeny {{customer.meta.KEY}}."

#: admin-templates/settings.php:183
msgid "Note: Customer meta tokens will return empty for guest orders."
msgstr "Uwaga: Tokeny meta klienta będą zwracać pustą wartość w przypadku zamówień złożonych przez gości."

