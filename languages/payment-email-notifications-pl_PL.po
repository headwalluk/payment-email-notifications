#: admin-templates/settings.php:55
msgid "Send Schedule"
msgstr "Wyślij harmonogram"

#: admin-templates/settings.php:59
msgid "Use these options to restrict when emails are sent. Emails that fall outside the schedule will simply be sent on the next eligible cron run."
msgstr "Skorzystaj z tych opcji, aby ograniczyć czas wysyłania wiadomości e-mail. Wiadomości e-mail, których wysłanie nie mieści się w harmonogramie, zostaną po prostu wysłane podczas następnego odpowiedniego uruchomienia zadania cron."

#: admin-templates/settings.php:68
msgid "Time-of-Day Window"
msgstr "Okno pory dnia"

#: admin-templates/settings.php:73
msgid "Only send emails within a specific time window"
msgstr "Wysyłaj e-maile wyłącznie w określonym przedziale czasowym"

#: admin-templates/settings.php:81
msgid "Window Times"
msgstr "Godziny otwarcia"

#: admin-templates/settings.php:86
msgid "to"
msgstr "do"

#. translators: %s: server timezone name, e.g. "Europe/London".
#: admin-templates/settings.php:93
#, php-format
msgid "Server timezone: %s. Emails due outside this window will be sent on the next cron run within the window."
msgstr "Strefa czasowa serwera: %s. Wiadomości e-mail, których termin wysyłki przypada poza tym przedziałem czasowym, zostaną wysłane podczas następnego uruchomienia zadania cron w ramach tego przedziału."

#: admin-templates/settings.php:103
msgid "Allowed Days"
msgstr "Dopuszczalne dni"

#: admin-templates/settings.php:108
msgid "Only send emails on specific days of the week"
msgstr "Wysyłaj e-maile tylko w określone dni tygodnia"

