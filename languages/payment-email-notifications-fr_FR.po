#. Plugin Name of the plugin
#: payment-email-notifications.php
msgid "Order Status Email Notifications"
msgstr "Notifications par e-mail concernant le statut des commandes"

#. Plugin URI of the plugin
#: payment-email-notifications.php
msgid "https://github.com/headwalluk/payment-email-notifications"
msgstr "https://github.com/headwalluk/payment-email-notifications"

#. Description of the plugin
#: payment-email-notifications.php
msgid "Send scheduled, WooCommerce-styled emails to customers based on how long an order has been at a given status."
msgstr "Envoyez à vos clients des e-mails programmés, au format WooCommerce, en fonction de la durée pendant laquelle une commande est restée dans un statut donné."

#. Author of the plugin
#: payment-email-notifications.php
msgid "Headwall"
msgstr "Paroi"

#. Author URI of the plugin
#: payment-email-notifications.php
msgid "https://headwall.tech"
msgstr "https://headwall.tech"

